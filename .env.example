# =============================================================================
# Prediction Market Anomaly & Signal Tracker — Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./prediction_market_tracker.db

# --- News API ---
# Provider: "newsapi" or "finnhub"
NEWS_API_PROVIDER=newsapi
NEWS_API_KEY=your_newsapi_key_here

# --- Kalshi (optional — for personal portfolio tracking) ---
# Only needed if you want to track your own Kalshi positions.
# Public market/trade data does NOT require auth.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# --- Anomaly Scoring ---
# Composite score threshold for flagging a bet as anomalous
ANOMALY_THRESHOLD=3.0
# Minimum bets for trader baseline computation
MIN_TRADER_BETS=5
# Minimum participants for market baseline computation
MIN_MARKET_PARTICIPANTS=3

# --- NLP ---
# Backend: "huggingface" (full models) or "vader" (lightweight fallback)
NLP_BACKEND=huggingface
# Directory to cache downloaded HuggingFace models
MODELS_CACHE_DIR=./models_cache

# --- Redis (production only) ---
USE_FAKE_REDIS=true
REDIS_URL=redis://localhost:6379/0

# --- Server ---
HOST=0.0.0.0
PORT=8000
